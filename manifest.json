{
  "manifest_version": 3,
  "name": "Pretty Markdown Navigator",
  "version": "1.2.1",
  "description": "Navega carpetas locales y lee tus archivos Markdown con un formato precioso, índice automático y búsqueda. 100% local.",
  "permissions": ["sidePanel", "storage", "tabs"],
  "action": {
    "default_title": "Pretty Markdown Navigator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
