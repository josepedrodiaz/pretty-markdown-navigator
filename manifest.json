{
  "manifest_version": 3,
  "name": "Pretty Markdown Navigator",
  "version": "1.4.1",
  "description": "Browse local folders and read your Markdown files with a beautiful viewer, automatic outline and in-document search. 100% local.",
  "permissions": ["sidePanel", "storage", "tabs"],
  "action": {
    "default_title": "Pretty Markdown Navigator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Open Pretty Markdown Navigator"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
